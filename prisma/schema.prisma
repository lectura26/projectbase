generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectVisibility {
  ONLY_ME
  TEAM
  ALL
}

enum RoutineInterval {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ActivityType {
  MAIL
  MEETING
  NOTE
  FILE
}

enum AppRole {
  ADMIN
  MEMBER
}

enum NotifyPreference {
  EMAIL_DAILY
  PUSH
  NONE
}

enum AiMatchSensitivity {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  OVERDUE_TASK
  ROUTINE_RESTARTED
  TASK_ASSIGNED
  AI_MATCH
}

/// Application user; `id` matches `auth.users.id` (UUID) from Supabase Auth.
model User {
  id             String           @id
  email          String           @unique
  name           String?
  image          String?
  appRole        AppRole          @default(MEMBER)
  notifyPreference   NotifyPreference   @default(EMAIL_DAILY)
  aiMatchSensitivity AiMatchSensitivity @default(MEDIUM)
  createdAt      DateTime         @default(now())

  ownedProjects  Project[]       @relation("ProjectOwnedBy")
  projectMembers ProjectMember[]
  assignedTasks Task[]           @relation("TaskAssignee")
  taskNotes      TaskNote[]
  comments       Comment[]
  uploadedFiles  File[]
  notifications  Notification[]
  teamInvitesSent PendingTeamMember[] @relation("TeamInviteInviter")

  focusProjectId String?
  focusDate      DateTime?
  focusProject   Project? @relation("UserFocusProject", fields: [focusProjectId], references: [id], onDelete: SetNull)

  icsEvents       IcsEvent[]
  calendarEvents  CalendarEvent[]
}

model Project {
  id              String            @id @default(cuid())
  name            String
  description     String?
  status          ProjectStatus     @default(NOT_STARTED)
  priority        Priority          @default(MEDIUM)
  visibility      ProjectVisibility @default(TEAM)
  startDate       DateTime?
  deadline        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  userId          String
  isRoutine       Boolean           @default(false)
  routineInterval RoutineInterval?
  tags            String[]          @default([])
  isTemplate      Boolean           @default(false)
  color           String            @default("#1a3167")

  user           User             @relation("ProjectOwnedBy", fields: [userId], references: [id], onDelete: Restrict)
  members        ProjectMember[]
  contacts       Contact[]
  tasks          Task[]
  comments       Comment[]
  activities     Activity[]
  files          File[]
  calendarEvents CalendarEvent[]
  icsEvents      IcsEvent[]

  userFocusSelections User[] @relation("UserFocusProject")

  @@index([userId])
}

model ProjectMember {
  id        String @id @default(cuid())
  projectId String
  userId    String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Contact {
  id        String @id @default(cuid())
  name      String
  email     String
  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  startDate   DateTime?
  deadline    DateTime?
  userId      String?
  projectId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user    User?   @relation("TaskAssignee", fields: [userId], references: [id], onDelete: SetNull)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments Comment[]
  notes    TaskNote[]

  @@index([projectId])
  @@index([userId])
}

model TaskNote {
  id        String   @id @default(cuid())
  content   String
  taskId    String?
  meetingId String?
  authorId  String
  createdAt DateTime @default(now())

  task    Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  meeting CalendarEvent? @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  author  User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([meetingId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  projectId String?
  taskId    String?
  meetingId String?
  createdAt DateTime @default(now())

  author  User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  project Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  meeting CalendarEvent? @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([projectId])
  @@index([taskId])
  @@index([meetingId])
}

model Activity {
  id            String       @id @default(cuid())
  type          ActivityType
  title         String
  source        String
  externalId    String
  date          DateTime
  projectId     String
  organizerName String?
  autoMatched   Boolean      @default(false)
  confirmed     Boolean      @default(false)
  createdAt     DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([externalId])
}

model File {
  id           String   @id @default(cuid())
  name         String
  fileType     String
  url          String
  storagePath  String?
  projectId    String
  uploadedById String
  createdAt    DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([uploadedById])
}

model CalendarEvent {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  startTime String?
  endTime   String?
  projectId String?
  userId    String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes    TaskNote[]
  comments Comment[]

  @@index([projectId])
  @@index([userId])
  @@index([date])
}

model IcsEvent {
  id          String    @id @default(cuid())
  userId      String
  title       String
  start       DateTime
  end         DateTime?
  location    String?
  description String?
  externalId  String
  projectId   String?
  createdAt   DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([userId, externalId])
  @@index([userId])
  @@index([start])
  @@index([projectId])
}

model Notification {
  id               String           @id @default(cuid())
  userId           String
  type             NotificationType
  message          String
  read             Boolean          @default(false)
  relatedProjectId String?
  relatedTaskId    String?
  createdAt        DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([relatedTaskId])
}

/// Pending team add until user signs in with matching email (see ensureAppUser).
model PendingTeamMember {
  id          String   @id @default(cuid())
  email       String
  name        String?
  appRole     AppRole  @default(MEMBER)
  invitedById String
  createdAt   DateTime @default(now())

  invitedBy User @relation("TeamInviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([email])
  @@index([invitedById])
}
